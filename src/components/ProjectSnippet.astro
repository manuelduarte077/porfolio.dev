---
import Anchor from "./common/Anchor.astro";

export type Props = {
  title: string;
  description: string;
  url: string;
  githubUrl?: string;
  liveUrl?: string;
  tags: string[];
  platform?: string;
};

const { title, description, url, githubUrl, liveUrl, tags, platform } =
  Astro.props;
console.log(`Project: ${title}, Platform: ${platform}`);
---

<div class="flex flex-col gap-3 pb-8">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
    <Anchor url={url} class="text-xl">
      {title}
    </Anchor>
    <div class="flex gap-2">
      {
        githubUrl ? (
          <Anchor url={githubUrl} class="text-base" external>
            Source Code
          </Anchor>
        ) : null
      }
      {
        liveUrl ? (
          <Anchor url={liveUrl} class="text-base" external>
            {platform?.toLocaleLowerCase() === "ios"
              ? "App Store"
              : platform?.toLocaleLowerCase() === "android"
              ? "Play Store"
              : "Live Demo"}
          </Anchor>
        ) : null
      }
    </div>
  </div>
  <p class="zag-text zag-transition">
    {description}
  </p>
  <div class="flex flex-row wrap gap-2">
    {
      tags.map((tag) => (
        <span class="-zag-text -zag-bg zag-transition px-2 py-1 text-sm font-semibold">
          {tag}
        </span>
      ))
    }
  </div>
</div>
